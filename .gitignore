.next/
out/
# Anchor to repo root — without the leading slash this matched any
# directory named 'build' at any depth, including app/(wizard)/case/[id]/build/,
# which silently dropped every wizard file from version control.
/build/
.DS_Store
*.pem
.env*.local
.vercel
*.tsbuildinfo
next-env.d.ts

# Research pipeline transient state — keep -sources.json, -evidence.json, -draft.md;
# ignore in-flight ids, raw API dumps, failures, and per-cluster intermediates.
reports/*.id
reports/*.id.partial
reports/*.raw.json
reports/*.failure.json
reports/_drafts/
reports/_progress.json
reports/_sequential_progress.json
reports/_source_discovery_progress.json
reports/_evidence_extraction_progress.json
reports/_draft_pass_progress.json
reports/_research_pass_progress.json

# Local env backups
.env.local.bak*
